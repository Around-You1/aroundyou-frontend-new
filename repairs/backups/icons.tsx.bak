import React from "react";

function pick(name: string, short: string) {
  const Component: React.FC<React.SVGProps<SVGSVGElement> & { title?: string }> = (props) => {
    const { title, ...rest } = props;
    return (
      <svg
        aria-hidden={title ? undefined : true}
        role={title ? "img" : "presentation"}
        width="1em"
        height="1em"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        strokeWidth={2}
        strokeLinecap="round"
        strokeLinejoin="round"
        {...rest}
      >
        {title ? <title>{title}</title> : null}
        <circle cx="12" cy="12" r="10" />
        <text x="12" y="16" textAnchor="middle" fontSize="8" fill="currentColor">{short}</text>
      </svg>
    );
  };
  Component.displayName = `Icon(${name})`;
  return Component;
}

