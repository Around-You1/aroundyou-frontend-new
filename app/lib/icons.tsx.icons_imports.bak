// app/lib/icons.tsx
// Central icon shim: export named icons used across the app.
// Maps many names to lucide-react icons and provides small SVG fallbacks for any missing names.
// This file is a temporary compatibility shim to unblock builds.
// Replace with direct lucide imports in components later if you prefer.

import React from "react";
import {
  ChevronDown,
  Globe,
  Mail,
  Phone,
  ExternalLink,
  Music,
  MapPin,
  Loader2,
  Copy,
  Edit,
  Trash2,
  ChevronRight,
  Search,
  Plus,
  X,
  Download,
  Printer,
  Check,
  RefreshCw,
  ArrowUp,
  ArrowDown,
  ChevronLeft,
  Eye,
  EyeOff,
  Tag,
  FileText as LucideFileText,
  Upload as LucideUpload,
  Navigation as LucideNavigation,
  Compass as LucideCompass,
  Store as LucideStore,
  Building2 as LucideBuilding2,
  LogOut as LucideLogOut,
  Baby as LucideBaby,
} from "lucide-react";

/* Tiny fallback icon component */
const Fallback = ({ title = "icon" }: { title?: string }) => (
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    strokeWidth="2"
    strokeLinecap="round"
    strokeLinejoin="round"
    aria-hidden="true"
    role="img"
  >
    <title>{title}</title>
    <circle cx="12" cy="12" r="8" />
    <path d="M12 8v4l2 2" />
  </svg>
);

/* Map lucide exports to the names used in the codebase */
export const ChevronDown = ChevronDown;
export const Globe = Globe;
export const Mail = Mail;
export const Phone = Phone;
export const ExternalLink = ExternalLink;
export const Music = Music;
export const MapPin = MapPin;
export const Loader2 = Loader2;
export const Copy = Copy;
export const Edit = Edit;
export const Trash2 = Trash2;
export const ChevronRight = ChevronRight;
export const Search = Search;
export const Plus = Plus;
export const X = X;
export const Download = Download;
export const Printer = Printer;
export const Check = Check;
export const RefreshCw = RefreshCw;
export const ArrowUp = ArrowUp;
export const ArrowDown = ArrowDown;
export const ChevronLeft = ChevronLeft;
export const Eye = Eye;
export const EyeOff = EyeOff;
export const Tag = Tag;

/* Icons that were referenced by name but may not exist as brand icons in lucide.
   Use lucide equivalents or fallbacks where appropriate.
*/
export const FileText = LucideFileText ?? Fallback;
export const Upload = LucideUpload ?? Fallback;
export const Navigation = LucideNavigation ?? Fallback;
export const Compass = LucideCompass ?? Fallback;
export const Store = LucideStore ?? Fallback;
export const Building2 = LucideBuilding2 ?? Fallback;
export const LogOut = LucideLogOut ?? Fallback;
export const Baby = LucideBaby ?? Fallback;

/* Social icons: lucide does not include brand icons; use Globe or ExternalLink as fallback */
export const Instagram = Globe;
export const Twitter = Globe;
export const Youtube = ExternalLink;

/* Aliases used in UI components */
export const CheckIcon = Check;
export const XIcon = X;
export const ChevronDownIcon = ChevronDown;
export const ChevronUpIcon = ChevronDown;

/* Fallback export */
export const FallbackIcon = Fallback;

/* Default export for convenience */
const Icon = {
  ChevronDown,
  Globe,
  Mail,
  Phone,
  ExternalLink,
  Music,
  MapPin,
  Loader2,
  Copy,
  Edit,
  Trash2,
  ChevronRight,
  Search,
  Plus,
  X,
  Download,
  Printer,
  Check,
  RefreshCw,
  ArrowUp,
  ArrowDown,
  ChevronLeft,
  Eye,
  EyeOff,
  Tag,
  FileText,
  Upload,
  Navigation,
  Compass,
  Store,
  Building2,
  LogOut,
  Baby,
  Instagram,
  Twitter,
  Youtube,
  CheckIcon,
  XIcon,
  ChevronDownIcon,
  ChevronUpIcon,
  FallbackIcon,
};

export default Icon;
