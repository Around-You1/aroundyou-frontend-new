import { useState } from "react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { ChevronDown, Globe, Mail, Phone, ExternalLink, Music, MapPin, Loader2, Copy, Edit, Trash2, ChevronRight, Search, Plus, X, Download, Printer } from 'lucide-react';
import { useToast } from "@/components/ui/use-toast";

interface ProfileReferenceCodeDisplayProps {
  entityType: "accommodation" | "restaurant" | "service" | "attraction";
  entityId: number;
  entityStringId?: string;
  currentCode?: string | null;
  onCodeUpdated?: (newCode: string) => void;
}

export default function ProfileReferenceCodeDisplay({
  currentCode,
}: ProfileReferenceCodeDisplayProps) {
  const [copied, setCopied] = useState(false);
  const { toast } = useToast();

  const displayCode = currentCode || "";

  const copyToClipboard = () => {
    if (displayCode) {
      navigator.clipboard.writeText(displayCode);
      setCopied(true);
      toast({ title: "Copied!", description: "Profile access code copied to clipboard" });
      setTimeout(() => setCopied(false), 2000);
    }
  };

  return (
    <div className="space-y-2 p-4 bg-muted/50 rounded-lg border border-border">
      <Label className="text-base font-semibold text-foreground">Profile Access Code</Label>
      <p className="text-xs text-muted-foreground">
        This code is automatically generated by the system and is the unique login credential for this profile. Keep it confidential.
      </p>
      <div className="flex gap-2 items-center">
        <Input
          value={displayCode}
          readOnly
          className="font-mono tracking-widest"
        />
        <Button type="button" variant="outline" size="sm" onClick={copyToClipboard} disabled={!displayCode}>
          {copied ? <Check className="h-4 w-4" /> : <Copy className="h-4 w-4" />}
        </Button>
      </div>
    </div>
  );
}
